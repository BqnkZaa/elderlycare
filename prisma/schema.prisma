  adlGrooming    AdlGroomingStatus?
  adlBathing     AdlBathingStatus?
  adlDressing    AdlDressingStatus?
  adlBowel       AdlBowelStatus?
  adlBladder     AdlBladderStatus?
  adlToilet      AdlToiletStatus?
  adlTransfer    AdlTransferStatus?
  adlMobility    AdlMobilityStatus?
  adlStairs      AdlStairsStatus?

  // Medical Complexity (Part 2)
  hasNgt                 Boolean @default(false)
  hasPeg                 Boolean @default(false)
  hasFoleyCatheter       Boolean @default(false)
  hasColostomy           Boolean @default(false)
  oxygenCannulaLiters    String? @db.VarChar(50)
  oxygenMaskLiters       String? @db.VarChar(50)
  ventilatorMode         String? @db.VarChar(50)
  needSuction            Boolean @default(false)
  
  woundsNone             Boolean @default(true)
  bedsoreStage1Location  String? @db.VarChar(100)
  bedsoreStage2Location  String? @db.VarChar(100)
  bedsoreStage3Location  String? @db.VarChar(100)
  bedsoreStage4Location  String? @db.VarChar(100)
  diabeticWoundLocation  String? @db.VarChar(100)
  surgicalWoundLocation  String? @db.VarChar(100)

  hasCapd                Boolean @default(false)
  hasHd                  Boolean @default(false)
  hasIvSupport           Boolean @default(false)
  requireBloodSugarCheck Boolean @default(false)

  // Cognitive & Behavioral (Part 3)
  cognitiveStatus         CognitiveStatus?
  aggressiveStatus        AggressiveStatus?
  noisyConfusionTimeframe String? @db.VarChar(100)
  talksToSelfQuietly      Boolean @default(false)
  psychiatricWithMeds     Boolean @default(false)
  psychiatricNoMeds       Boolean @default(false)

  // Safety Risks (Part 4)
  fallHistoryLevel FallHistoryLevel?
  bradenScale      BradenScale?
  infectionNone    Boolean          @default(true)
  infectionDetails String?          @db.VarChar(200)
  frailtyScore     FrailtyScore?

  // Hospital & Medications (Part 5)
  recentDischargeDate      String? @db.VarChar(50) 
  recentHospital           String? @db.VarChar(150)
  recentAdmissionReason    String? @db.Text
  nextAppointmentDate      String? @db.VarChar(50)
  
  polypharmacy             Polypharmacy?
  highAlertAnticoagulant   Boolean      @default(false)
  highAlertDiabetic        Boolean      @default(false)
  highAlertPsychiatric     Boolean      @default(false)

  message   String?  @db.Text
  status    String   @default("PENDING") @db.VarChar(20) // PENDING, CONTACTED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("inquiries")
}

/// Model for managing partner centers (PID) and their supported patient types
model PartnerCenter {
  id          String   @id @default(uuid())
  pid         String   @unique @db.VarChar(20) // Center Code e.g., PID001
  name        String   @db.VarChar(200)        // Center Name
  contact     String?  @db.VarChar(255)        // Contact Phone
  address     String?  @db.Text                // Address
  
  // --- Supported Patient Types (Referencing Section 2 of Registration Form) ---
  
  // Self Help Capability (การช่วยเหลือตัวเอง)
  supportIndependentNonBedridden Boolean @default(true)
  supportIndependentBedridden    Boolean @default(false)
  supportDependentBedridden      Boolean @default(false)
  
  // Diet Types (การทานอาหาร)
  supportNormalDiet   Boolean @default(true)
  supportSoftDiet     Boolean @default(true)
  supportNeedsFeeding Boolean @default(false)
  supportTubeFeeding  Boolean @default(false)

  // Medical Support Needs (เครื่องมือ/การพยาบาลพิเศษ)
  supportTracheostomy Boolean @default(false) // เจาะคอ
  supportBedsore      Boolean @default(false) // แผลกดทับ
  supportAirMattress  Boolean @default(false) // ที่นอนลม
  supportOxygen       Boolean @default(false) // อ็อกซิเจน
  supportVentilator   Boolean @default(false) // เครื่องช่วยหายใจ

  // Psychiatric & Behavioral (จิตเวช/พฤติกรรม)
  supportPsychiatric           Boolean @default(false) // จิตเวช/อัลไซเมอร์
  supportAggressiveBehavior    Boolean @default(false) // โวยวาย/ด่าทอ
  supportPsychiatricMedication Boolean @default(false) // ยาระงับอาการ

  // System Metadata
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("partner_centers")
}

// ============================================
// CHAT SYSTEM MODELS
// ============================================

enum MessageType {
  TEXT
  SYSTEM
}

model Conversation {
  id        String   @id @default(uuid())
  name      String?  @db.VarChar(100)
  isGroup   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants ConversationParticipant[]
  messages     Message[]

  @@map("conversations")
}

model ConversationParticipant {
  id             String   @id @default(uuid())
  conversationId String
  userId         String
  joinedAt       DateTime @default(now())
  lastReadAt     DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("conversation_participants")
}

model Message {
  id             String      @id @default(uuid())
  conversationId String
  senderId       String
  content        String      @db.Text
  type           MessageType @default(TEXT)
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@map("messages")
}
